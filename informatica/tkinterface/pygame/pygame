import pygame
import sys

pygame.init()
screen=pygame.display.set_mode((800,600))
pygame.display.set_caption('il mio primo gioco in pygame!')

background_color = (0,0,0)#nero

running = True
while running:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running=False
        
    screen.fill(background_color)

    #blocco istruzioni per il gioco

    pygame.display.flip()


pygame.quit()
sys.exit()